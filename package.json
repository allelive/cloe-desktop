{
  "name": "cloe-desktop",
  "version": "1.2.1",
  "description": "Cloe - AI Desktop Companion with Expressions and Voice",
  "main": "launcher.js",
  "author": {
    "name": "JakimLi & Cloe",
    "email": "jakim@cloe.ai"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "vite build && electron .",
    "pack": "vite build && electron-builder --mac",
    "pack:dir": "vite build && electron-builder --mac --dir",
    "test:bridge": "node test/bridge.test.js",
    "test:smoke": "node test/smoke-test.js",
    "test:smoke:dev": "node test/smoke-test.js --dev"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ai.cloe.desktop",
    "productName": "Cloe",
    "copyright": "Copyright © 2026 JakimLi & Cloe",
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-${arch}.dmg",
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "dist/**/*",
      "launcher.js",
      "preload.js",
      "node_modules/ws/**/*",
      "node_modules/node-pty/**/*",
      "node_modules/xterm/**/*",
      "node_modules/@xterm/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*.py"
        ]
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
